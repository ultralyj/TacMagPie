
    <mujoco model="Press">
        <include file="scene.xml" />
        <compiler autolimits="true" meshdir="assets" />
        <option solver="Newton" tolerance="1e-8" timestep="1e-05" 
           integrator="implicitfast"/>
        <size memory="100M" />
        <asset>
            <mesh file="./CNC3018.STL" name="CNC3018" scale="0.001 0.001 0.001" />
            <mesh file="./board.STL" name="board" scale="0.001 0.001 0.001" />
            <mesh file="./rig.STL" name="rig" scale="0.001 0.001 0.001" />
            <mesh file="./indenter_type2.STL" name="indenter" scale="0.001 0.001 0.001" />
            <mesh file="./press_sensor.STL" name="press_sensor" scale="0.001 0.001 0.001" />
            <mesh file="./press_outer.STL" name="press_outer" scale="0.001 0.001 0.001" />
        </asset>
        <worldbody>
            
            <flexcomp name="A" type="grid" count="8 8 2" spacing=".002 .002 .002" pos="0 0 0.03"
              radius=".0005" rgba="0 .7 .7 1" dim="3" mass="1e-2">
                <contact condim="3" solref="0.01 1" solimp=".95 .99 .0001" selfcollide="none"/>
                <edge damping="1"/>
                <elasticity young="1.2e5" poisson="0.4"/>
            </flexcomp>
            <body name="indenter" pos="-0.006 -0.006 0.118" quat="0 1 0 0">
                <joint name="indenter_slider" type="slide" axis="0 0 1" range="0 0.1"
                    damping="10" stiffness="1" />
                <geom type="mesh" mesh="indenter"  pos="-0.0173 0.0173 0" quat="0.717 0.717 0 0" name="indenter_geom" rgba="0.8 0.3 0.3 1"  solref="0.001 0.9"/>
                <site name="force_sensor_site" type="sphere" size="0.0005" pos="0 0 0.005"
                    rgba="1 0 0 1" />
                <body name="outer" pos="0 0 0" quat="0 0 0 1">
                    <geom type="mesh" mesh="press_outer" name="press_outer_geom" pos="-0.022 0.022 -0.05" quat="0.717 0.717 0 0" rgba="0.4 0.4 0.4 1" />
                </body>
            </body>
        </worldbody>
        <actuator>
            <position name="position_control" joint="indenter_slider" kp="500" kv="10" ctrlrange="0.0 0.1"/>
        </actuator>
        <sensor>
            <force name="force_sensor" site="force_sensor_site" />
            <actuatorfrc name="actuator_force" actuator="position_control"/>
            <jointpos name="indenter_position" joint="indenter_slider"/>
            <jointvel name="indenter_velocity" joint="indenter_slider"/>
        </sensor>

    </mujoco>
    